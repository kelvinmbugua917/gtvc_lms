# Gilgil Technical and Vocational College (GTVC) LMS Production Configuration

APP_NAME="Gilgil TVC LMS"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Africa/Nairobi
APP_URL=http://localhost

# MySQL Database Settings (XAMPP / InfinityFree / Hostinger)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gilgil_lms
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# File Upload Settings
MAX_UPLOAD_SIZE_BYTES=20971520
ALLOWED_FILE_EXTENSIONS="pdf,doc,docx,xls,xlsx,ppt,pptx,zip,rar,jpg,jpeg,png,gif,txt"
